pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/karanjashan49-beep/clones.git'
            }
        }

        stage('Build') {
            steps {
                echo "No build required for PHP"
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                cp -r * /var/www/html/
                '''
            }
        }
    }
}
